            "properties": {
                "code": "nome = \"{{loop_de_produtos.item.nome}}\"\n\nif \"vestidos\" in nome or \"vestido\" in nome:\n    return 2\nelif \"saia\" in nome:\n    return 3\nelif \"blusa\" in nome:\n    return 4\nelif \"salopete\" in nome:\n    return 5\nelif \"chemise\" in nome:\n    return 6\nelif \"calça\" in nome or \"calca\" in nome:\n    return 7\nelif \"bermuda\" in nome:\n    return 8\nelif \"regata\" in nome:\n    return 9\nelif \"shorts\" in nome or \"short\" in nome:\n    return 10\nelif \"jaqueta\" in nome:\n    return 11\nelif \"macacão\" in nome or \"macacao\" in nome:\n    return 12\nelif \"blazer\" in nome:\n    return 13\nelif \"cropped\" in nome:\n    return 14\nelif \"colete\" in nome:\n    return 15\nelif \"t-shirt\" in nome:\n    return 16\nelif \"cardigan\" in nome:\n    return 17\nelif \"top\" in nome:\n    return 18\nelif \"kimono\" in nome:\n    return 19\nelif \"conjunto\" in nome:\n    return 20\nelif \"lenço\" in nome or \"lenco\" in nome:\n    return 21\nelif \"jardineira\" in nome:\n    return 22\nelif \"parka\" in nome:\n    return 23\nelif \"sobretudo\" in nome:\n    return 25\nelif \"casaqueto\" in nome:\n    return 26\nelif \"cinto\" in nome:\n    return 30\nelif \"bomber\" in nome:\n    return 31\nelif \"body\" in nome:\n    return 32\nelif \"camisa\" in nome:\n    return 1\nelse:\n    return 0 ",
